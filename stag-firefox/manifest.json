{
  "manifest_version": 2,
  "name": "stag",
  "version": "1.0.0",
  "description": "Drag any image to download it in the highest resolution available. Handles thumbnails, srcsets, base64, and all image formats.",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "<all_urls>",
    "http://127.0.0.1:57432/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "stag@extension",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  }
}
